{
  "name": "lead-pipeline-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "template": {
    "name": "todoapp",
    "displayName": "Basic Todo App",
    "description": "End-to-end Fabric-authenticated todo CRUD with a Rayfin data model and per-user row-level security — a working starter that exercises the full data path"
  },
  "scripts": {
    "predev": "rayfin env --framework vite",
    "prebuild": "rayfin env --framework vite",
    "dev": "rayfin up --exclude-services staticHosting && vite",
    "dev:preview": "vite --mode preview",
    "build": "tsc -b && vite build",
    "build:fabric": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "rayfin:db": "rayfin up db apply"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.11.0",
    "@microsoft/rayfin-auth-provider-fabric": "^1.33.1",
    "@microsoft/rayfin-client": "^1.33.1",
    "@microsoft/rayfin-core": "^1.33.1",
    "@microsoft/rayfin-data": "^1.33.1",
    "@tailwindcss/vite": "^4.1.11",
    "powerbi-client": "^2.23.10",
    "powerbi-client-react": "^2.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@microsoft/rayfin-cli": "^1.33.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^24.1.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  }
}
